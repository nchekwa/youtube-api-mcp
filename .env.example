# ======================
# API PATHS
# ======================
#_APP_ROOT_PATH=                           # Root path for API (default: empty string)
#_APP_API_PREFIX=/api/v1                   # API prefix for all endpoints (default: /api/v1)
#_APP_CORS_ALLOW_ORIGINS=                  # Comma-separated allowed origins; leave empty to disable CORS middleware
#_APP_CORS_ALLOW_CREDENTIALS=false         # Allow credentials for CORS requests
#_APP_CORS_ALLOW_METHODS=GET,POST,DELETE,OPTIONS # Allowed CORS methods
#_APP_CORS_ALLOW_HEADERS=*                 # Allowed CORS headers

# ======================
# CACHE CONFIGURATION
# ======================
#_APP_CACHE_DIR=./cache                    # Directory for cache storage (default: ./cache)
#_APP_MAX_CACHE_SIZE_MB=0                  # Maximum cache size in megabytes; 0 means unlimited (default: 0)
#_APP_CACHE_TTL_DAYS=0                     # Cache time-to-live in days; 0 means no expiration (default: 0)
#_APP_JOBS_DIR=./data/jobs                 # Directory for background job status JSON files
#_APP_WORK_DIR=./data/work                 # Directory for temporary audio work files

# ======================
# FUNCTIONALITY
# ======================
#_APP_USE_CACHE_DEFAULT=true               # Enable caching by default (default: true)
#_APP_TRANSCRIPT_FROM_AUDIO=false          # Auto-queue transcript_from_audio processing when direct YouTube transcript fetch fails
#_APP_MCP_HIDE_CLEAR_CACHE=false           # Hide the clear_cache MCP tool from tools/list when set to true
#_APP_BACKGROUND_JOB_CONCURRENCY=1         # Number of concurrent background transcription jobs
#_APP_JOB_POLL_TTL_DAYS=7                  # Days to retain completed/failed job status files
#_APP_JOB_CLEANUP_TEMP_FILES=true          # Remove downloaded/normalized audio after each job

# ======================
# TRANSCRIPTION
# ======================
#_APP_TRANSCRIPTION_BACKEND=faster-whisper # Transcription backend: faster-whisper|assembly|openai|gemini
#_APP_WHISPER_MODEL=large-v3               # Whisper model name for faster-whisper
#_APP_WHISPER_DEVICE=cpu                   # Device: cpu or cuda
#_APP_WHISPER_COMPUTE_TYPE=int8            # Compute type for faster-whisper
#_APP_YTDLP_SOCKET_TIMEOUT_SECONDS=120     # yt-dlp socket timeout in seconds
#_APP_FFMPEG_AUDIO_RATE=16000              # Output sample rate for Whisper-ready WAV
#_APP_FFMPEG_AUDIO_CHANNELS=1              # Output audio channels for Whisper-ready WAV
#_APP_TRANSCRIPTION_PROVIDER_TIMEOUT_SECONDS=1800 # Timeout for external transcription providers in seconds
#_APP_TRANSCRIPTION_PROVIDER_POLL_SECONDS=3       # Poll interval for asynchronous providers in seconds
#_APP_API_KEY=                             # API key for the selected transcription provider backend only; does not enable incoming API/MCP auth
#_APP_BASE_URL=                            # Base URL for the selected transcription provider backend
#_APP_MODEL=                               # Model name for the selected transcription provider backend
#_APP_LANGUAGE_DETECTION=true              # Language detection flag for supported backends
#_APP_GEMINI_TRANSCRIPTION_PROMPT=Transcribe this audio verbatim. Return JSON with keys 'transcript' and 'language'. The 'language' value should be a short language code if detectable, otherwise 'unknown'.

# ======================
# API KEY AUTHENTICATION
# ======================
#_APP_X_API_KEY=your-secret-api-key-here   # API key for incoming HTTP/MCP authentication (leave empty to disable)
#_APP_X_API_KEY_HEADER=X-API-Key           # HTTP header name for API key (default: X-API-Key)

# ======================
# SYSTEM
# ======================
#_APP_LOG_LEVEL=INFO                       # Logging level: DEBUG|INFO|WARNING|ERROR|CRITICAL (default: INFO)
#_APP_PORT=8000                            # Server port number (default: 8000)